# Backend Configuration
NODE_ENV=development
PORT=3000

# Database
DB_TYPE=sqlite
DB_PATH=../database/clinica_5m.db
# Para PostgreSQL (produção)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=clinica_5m
# DB_USER=postgres
# DB_PASSWORD=sua_senha

# JWT
JWT_SECRET=sua_chave_secreta_aqui_muito_longa_e_segura
JWT_EXPIRE=7d

# Firebase (para notificações)
FIREBASE_PROJECT_ID=seu_projeto
FIREBASE_PRIVATE_KEY=sua_chave_privada
FIREBASE_CLIENT_EMAIL=seu_email

# Email (para notificações)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_aplicacao

# Logging
LOG_LEVEL=debug
